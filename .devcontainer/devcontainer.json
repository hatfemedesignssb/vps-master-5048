{
  "name": "Ultimate VPS",
  "image": "mcr.microsoft.com/devcontainers/python:3.10",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [
    5000
  ],
  "portsAttributes": {
    "5000": {
      "label": "API Server",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  }
}